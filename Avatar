function deletePlayer(id){

    const player = app.players.find(p => p.id === id);

    if(!player) return;

    if(!ask(`"${player.name}" adlı oyuncu silinsin mi?`))
        return;

    app.players = app.players.filter(p => p.id !== id);

    app.tableSeats = app.tableSeats.map(seat =>
    seat === id ? null : seat
);
    
    save();

    renderPlayers();

renderTable();
    
}

